          "rawSql": "SELECT\r\n  date AS time,\r\n  btc_value,\r\n  STDDEV(btc_value) OVER (\r\n    ORDER BY\r\n      date ROWS BETWEEN 19 PRECEDING\r\n      AND CURRENT ROW\r\n  ) AS stddev,\r\n  -- Upper band\r\n  AVG(btc_value) OVER (\r\n    ORDER BY\r\n      date ROWS BETWEEN 19 PRECEDING\r\n      AND CURRENT ROW\r\n  ) + 2 * STDDEV(btc_value) OVER (\r\n    ORDER BY\r\n      date ROWS BETWEEN 19 PRECEDING\r\n      AND CURRENT ROW\r\n  ) AS upper_band,\r\n  -- Lower band\r\n  AVG(btc_value) OVER (\r\n    ORDER BY\r\n      date ROWS BETWEEN 19 PRECEDING\r\n      AND CURRENT ROW\r\n  ) - 2 * STDDEV(btc_value) OVER (\r\n    ORDER BY\r\n      date ROWS BETWEEN 19 PRECEDING\r\n      AND CURRENT ROW\r\n  ) AS lower_band\r\nFROM\r\n  sayso_btc_eur_price_hist;",
